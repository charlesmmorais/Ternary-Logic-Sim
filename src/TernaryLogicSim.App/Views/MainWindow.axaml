<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:editor="clr-namespace:TernaryLogicSim.App.Editor"
        x:Class="TernaryLogicSim.App.Views.MainWindow"
        Width="1180" Height="760"
        MinWidth="860" MinHeight="540"
        Title="Ternary-Logic-Sim — simulador de lógica ternária balanceada">

  <Window.Styles>
    <!-- Botões da paleta compactos para caber mais itens -->
    <Style Selector="Border.palette Button">
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
      <Setter Property="Padding" Value="8,4"/>
      <Setter Property="FontSize" Value="12"/>
    </Style>
    <Style Selector="TextBlock.section">
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="Foreground" Value="#8A8FA3"/>
      <Setter Property="Margin" Value="2,8,0,2"/>
    </Style>
  </Window.Styles>

  <DockPanel LastChildFill="True">

    <!-- Barra superior -->
    <Border DockPanel.Dock="Top" Background="#262830" Padding="10,8">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Text="🔺 Ternary-Logic-Sim" FontWeight="Bold" FontSize="15"
                   VerticalAlignment="Center" Margin="0,0,12,0"/>
        <Button Content="Exemplo: somador" Click="OnLoadDemo"/>
        <Button Content="Limpar" Click="OnClear"/>
        <Border Width="1" Background="#3A3D48" Margin="6,2"/>
        <Button Content="💾 Salvar" Click="OnSave"/>
        <Button Content="📂 Abrir" Click="OnOpen"/>
        <Button Content="➕ Criar chip…" Click="OnCreateChip"/>
        <TextBlock Text="🔴 N=-1   ⚫ O=0   🟢 P=+1"
                   VerticalAlignment="Center" Margin="16,0,0,0" Foreground="#AAB"/>
      </StackPanel>
    </Border>

    <!-- Rodapé / status -->
    <Border DockPanel.Dock="Bottom" Background="#262830" Padding="10,6">
      <TextBlock x:Name="StatusText" Foreground="#99A" FontSize="12"
                 Text="Clique numa porta para adicioná-la · Arraste o corpo · Saída→Entrada liga um fio · Clique em IN para alternar N/O/P · Botão direito apaga chip OU fio"/>
    </Border>

    <!-- Paleta à esquerda (rolável) -->
    <Border DockPanel.Dock="Left" Background="#23252C" Width="158" Padding="8" Classes="palette">
      <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="4">
          <TextBlock Classes="section" Text="ENTRADAS / SAÍDAS"/>
          <Button Content="IN (3 estados)" Tag="Input"  Click="OnAddChip"/>
          <Button Content="OUT (LED)"      Tag="Output" Click="OnAddChip"/>

          <TextBlock Classes="section" Text="CONSTANTES"/>
          <Button Content="N (-1)" Tag="ConstNeg"  Click="OnAddChip"/>
          <Button Content="O (0)"  Tag="ConstZero" Click="OnAddChip"/>
          <Button Content="P (+1)" Tag="ConstPos"  Click="OnAddChip"/>

          <TextBlock Classes="section" Text="INVERSORES"/>
          <Button Content="TINV (STI)" Tag="Not" Click="OnAddChip"/>
          <Button Content="NTI"        Tag="Nti" Click="OnAddChip"/>
          <Button Content="PTI"        Tag="Pti" Click="OnAddChip"/>

          <TextBlock Classes="section" Text="PORTAS"/>
          <Button Content="TMIN (AND)" Tag="Min"       Click="OnAddChip"/>
          <Button Content="TMAX (OR)"  Tag="Max"       Click="OnAddChip"/>
          <Button Content="NMIN"       Tag="Nmin"      Click="OnAddChip"/>
          <Button Content="NMAX"       Tag="Nmax"      Click="OnAddChip"/>
          <Button Content="CONSENSUS"  Tag="Consensus" Click="OnAddChip"/>
          <Button Content="ANY"        Tag="AnyGate"   Click="OnAddChip"/>
          <Button Content="MUL"        Tag="Mul"       Click="OnAddChip"/>

          <TextBlock Classes="section" Text="UNÁRIOS"/>
          <Button Content="SHIFT ▲" Tag="ShiftUp"   Click="OnAddChip"/>
          <Button Content="SHIFT ▼" Tag="ShiftDown" Click="OnAddChip"/>

          <TextBlock Classes="section" Text="ARITMÉTICA"/>
          <Button Content="FULL ADDER" Tag="FullAdder" Click="OnAddChip"/>

          <TextBlock Classes="section" Text="MEUS CHIPS"/>
          <StackPanel x:Name="CustomPalette" Spacing="4"/>
          <TextBlock x:Name="NoCustomHint" Text="(crie com '➕ Criar chip…')"
                     FontSize="10" Foreground="#6A6F80" Margin="2,0" TextWrapping="Wrap"/>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- Canvas do editor -->
    <editor:EditorCanvas x:Name="EditorSurface"/>

  </DockPanel>
</Window>
